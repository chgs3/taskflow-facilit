{
  "info": {
    "name": "TaskFlow API",
    "description": "Coleção Postman para testar os endpoints principais da API TaskFlow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Listar tarefas",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks"]
        }
      }
    },
    {
      "name": "Buscar tarefas",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tasks?search=api",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks"],
          "query": [
            {
              "key": "search",
              "value": "api"
            }
          ]
        }
      }
    },
    {
      "name": "Filtrar por status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tasks?status=A_FAZER",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks"],
          "query": [
            {
              "key": "status",
              "value": "A_FAZER"
            }
          ]
        }
      }
    },
    {
      "name": "Criar tarefa",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Criar documentação da API\",\n  \"description\": \"Documentar os principais endpoints no Swagger e no README.\",\n  \"status\": \"A_FAZER\",\n  \"assignee\": \"Caique\",\n  \"dueDate\": \"2026-05-10T23:59:59.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks"]
        }
      }
    },
    {
      "name": "Criar tarefa sem título",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Esta requisição deve retornar erro de validação.\",\n  \"status\": \"A_FAZER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks"]
        }
      }
    },
    {
      "name": "Buscar tarefa por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "{{taskId}}"]
        }
      }
    },
    {
      "name": "Editar tarefa",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Criar documentação completa da API\",\n  \"description\": \"Atualizar Swagger, README e coleção Postman.\",\n  \"status\": \"EM_PROGRESSO\",\n  \"assignee\": \"Caique\",\n  \"dueDate\": \"2026-05-15T23:59:59.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "{{taskId}}"]
        }
      }
    },
    {
      "name": "Alterar status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"CONCLUIDO\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "{{taskId}}", "status"]
        }
      }
    },
    {
      "name": "Excluir tarefa",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "{{taskId}}"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3333"
    },
    {
      "key": "taskId",
      "value": ""
    }
  ]
}